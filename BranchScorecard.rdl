  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="Branch_CX_Performance">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=.\SQLEXPRESS;Initial Catalog=BranchCX_Intelligence</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>043b3d76-c3a1-49c3-82d5-7adf136f0308</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DS_BranchKPI">
      <Query>
        <DataSourceName>Branch_CX_Performance</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportMonth">
            <Value>=Parameters!ReportMonth.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    k.branch_code,
    k.branch_name,
    k.region,
    k.complaint_count,
    k.ces_avg,
    k.nps_score,
    FORMAT(k.deposit_total, 'N0')  AS deposit_display,
    CASE
        WHEN k.ces_avg &gt;= 4.0 THEN '#d4edda'   -- green background
        WHEN k.ces_avg &gt;= 3.0 THEN '#fff3cd'   -- amber background
        ELSE                      '#f8d7da'   -- red background
    END                          AS ces_colour,
    CASE
        WHEN k.complaint_count &lt;= 5  THEN '#d4edda'
        WHEN k.complaint_count &lt;= 15 THEN '#fff3cd'
        ELSE                           '#f8d7da'
    END                          AS complaint_colour
FROM   dbo.Staging_BranchKPI k
WHERE  k.report_month = @ReportMonth
ORDER BY k.region, k.complaint_count DESC;</CommandText>
      </Query>
      <Fields>
        <Field Name="branch_code">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>branch_code</DataField>
        </Field>
        <Field Name="branch_name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>branch_name</DataField>
        </Field>
        <Field Name="region">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>region</DataField>
        </Field>
        <Field Name="complaint_count">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>complaint_count</DataField>
        </Field>
        <Field Name="ces_avg">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ces_avg</DataField>
        </Field>
        <Field Name="nps_score">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>nps_score</DataField>
        </Field>
        <Field Name="deposit_display">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>deposit_display</DataField>
        </Field>
        <Field Name="ces_colour">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ces_colour</DataField>
        </Field>
        <Field Name="complaint_colour">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>complaint_colour</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
